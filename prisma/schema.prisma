generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
  USER
}

enum MovieStatus {
  ONGOING
  COMPLETED
}

enum MovieAudioType {
  NONE
  SUB
  DUBBED
}

enum StorageProvider {
  EXTERNAL
  R2
}

enum ServerSourceType {
  EMBED
  DIRECT_VIDEO
}

model User {
  id            String    @id @default(uuid())
  username      String    @unique // Đăng nhập bằng username hoặc email (bắt buộc)
  email         String?   @unique // Optional
  emailVerified DateTime? // Chỉ set khi user đã liên kết mail và verify
  name          String?
  password      String
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  watchHistory WatchHistory[]
  favorites    Favorite[]
}

model WatchHistory {
  id             String   @id @default(uuid())
  userId         String
  movieId        Int
  episodeId      Int?     // Tập đang xem
  progressSeconds Int     @default(0)
  lastWatchedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([userId])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  movieId   Int
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([userId])
}



model Movie {
  id            Int     @id @default(autoincrement())
  slug          String  @unique
  /** Mã phim public, dùng để hiển thị / path, ví dụ 100001, 100002... */
  publicId      Int     @unique
  channel       String  @default("dramahd")
  title         String
  originalTitle String?
  description   String?
  poster        String?
  backdrop      String?

  year       Int?
  status     MovieStatus    @default(ONGOING)
  audioType  MovieAudioType @default(NONE)
  views      Int            @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  genres        Genre[]
  tags          Tag[]
  labels        Label[]
  episodes      Episode[]
  watchHistory  WatchHistory[]
  favorites     Favorite[]
  r2Files       R2File[]

  @@index([slug])
}

model Channel {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Episode {
  id      Int @id @default(autoincrement())
  movieId Int

  name          String 
  episodeNumber Int
  slug          String?
  watchSlug     String?
  subtitleUrl   String?

  createdAt DateTime @default(now())

  movie   Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  servers Server[]
  r2Files R2File[]

  @@unique([movieId, episodeNumber])
  @@unique([movieId, watchSlug])
  @@index([movieId])
}

model Server {
  id        Int @id @default(autoincrement())
  episodeId Int

  name            String // VD: MixDrop, StreamTape, Okru
  embedUrl        String // Legacy URL, giữ để tương thích cũ
  sourceType      ServerSourceType @default(EMBED)
  storageProvider StorageProvider  @default(EXTERNAL)
  /** Khi server dùng R2, trỏ tới bản ghi R2File tương ứng; null nếu dùng nguồn ngoài */
  r2FileId       String?
  objectKey      String?
  playbackUrl    String?
  subtitleUrl    String?
  vastTagUrl     String?
  mimeType       String?
  fileSizeBytes  Int?
  durationSeconds Int?
  priority        Int     @default(0) // server chính load trước
  isActive        Boolean @default(true)

  createdAt DateTime @default(now())

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  r2File  R2File? @relation(fields: [r2FileId], references: [id], onDelete: SetNull)

  @@index([episodeId])
  @@index([r2FileId])
}

model Genre {
  id    Int    @id @default(autoincrement())
  slug  String @unique
  name  String
  order Int    @default(0)

  movies Movie[]

  @@index([slug])
}

model Tag {
  id    Int    @id @default(autoincrement())
  slug  String @unique // tag
  name  String
  order Int    @default(0)

  movies Movie[]

  @@index([slug])
}

/** Nhãn hiển thị trên đầu thẻ phim: Hot, Phim mới, Đang chiếu, v.v. */
model Label {
  id             Int     @id @default(autoincrement())
  slug           String  @unique
  name           String
  order          Int     @default(0)
  textColor      String? // Màu chữ (hex hoặc CSS), VD: #fff
  backgroundColor String? // Màu nền (hex hoặc CSS), VD: #e11d48

  movies Movie[]

  @@index([slug])
}

// --- R2 file/folder (metadata trong DB, folder chỉ để nhóm; file có thể ở root bucket) ---

model R2Folder {
  id        String    @id @default(uuid())
  bucket    String
  prefix    String // prefix đầy đủ, ví dụ videos/nsh/phim-a/
  name      String // tên hiển thị (segment cuối của prefix)
  parentId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  parent   R2Folder?  @relation("R2FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children R2Folder[] @relation("R2FolderTree")
  files    R2File[]

  @@unique([bucket, prefix])
  @@index([bucket])
  @@index([parentId])
}

model R2File {
  id            String    @id @default(uuid())
  bucket        String
  key           String // full object key trên R2
  folderId      String? // null = file ở root bucket
  displayName   String // tên file để tìm kiếm trong DB
  sizeBytes     Int?
  mimeType      String?
  lastModifiedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  folder R2Folder? @relation(fields: [folderId], references: [id], onDelete: Cascade)
  /** File này thuộc phim nào (nếu là video/chung cho một phim cụ thể) */
  movieId Int?
  /** File này thuộc tập nào (nếu là video của một tập cụ thể) */
  episodeId Int?

  movie   Movie?   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  episode Episode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  servers Server[]

  @@unique([bucket, key])
  @@index([folderId])
  @@index([bucket, displayName])
  @@index([movieId])
  @@index([episodeId])
}